PORT=8080
PUBLIC_BASE_URL=https://your-disciplica-api.example.com

DATABASE_URL=jdbc:postgresql://your-postgres-host:5432/disciplica
DATABASE_USERNAME=disciplica
DATABASE_PASSWORD=change-this

JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters
JWT_ISSUER=disciplica
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
