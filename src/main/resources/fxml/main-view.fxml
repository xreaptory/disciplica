<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="View.MainController">
    <top>
        <MenuBar>
            <menus>
                <Menu text="File">
                    <items>
                        <MenuItem fx:id="menuNewAppMI" text="New window" onAction="#handleNewWindow" />
                        <SeparatorMenuItem />
                        <MenuItem fx:id="menuCloseMI" text="Close" onAction="#handleClose" />
                    </items>
                </Menu>
                <Menu text="Edit" />
                <Menu text="View" />
            </menus>
        </MenuBar>
    </top>

    <left>
        <VBox spacing="10.0" prefWidth="180.0">
            <padding>
                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
            </padding>
            <children>
                <Button fx:id="dashboardBTN" text="Dashboard" maxWidth="1.7976931348623157E308" onAction="#handleDashboard" />
                <Button fx:id="habitsBTN" text="Habits" maxWidth="1.7976931348623157E308" onAction="#handleHabits" />
                <Button fx:id="statsBTN" text="Stats" maxWidth="1.7976931348623157E308" onAction="#handleStats" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="10.0">
            <padding>
                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
            </padding>
            <children>
                <Label text="Habit List" />
                <Button text="Add Habit" onAction="#onAddHabit" />
                <ListView fx:id="habitListView" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="8.0" right="8.0" bottom="8.0" left="8.0" />
                    </padding>
                    <style>-fx-background-color: white; -fx-background-radius: 6;</style>
                </ListView>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="12.0">
            <padding>
                <Insets top="8.0" right="12.0" bottom="8.0" left="12.0" />
            </padding>
            <children>
                <Label fx:id="statusLabel" text="Ready" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lastSavedLabel" text="Last saved: ..." />
            </children>
        </HBox>
    </bottom>
</BorderPane>
